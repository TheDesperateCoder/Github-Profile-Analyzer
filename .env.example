PORT=3000

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=github_analyzer

# Optional but recommended: a GitHub Personal Access Token (no scopes needed
# for public data) raises the GitHub API rate limit from 60/hr to 5000/hr.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# How many minutes a stored analysis is considered "fresh". Re-analyzing a
# username within this window returns the cached DB row instead of
# hitting the GitHub API again. Pass ?refresh=true to force a re-fetch.
CACHE_TTL_MINUTES=60
